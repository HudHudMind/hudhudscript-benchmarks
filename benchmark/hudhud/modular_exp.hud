let start = Date.to_millis();
fn mod_exp(base, exp, mod) {
    let result = 1;
    let b = base % mod;
    let e = exp;
    while (e > 0) {
        if (e % 2 == 1) {
            result = (result * b) % mod;
        }
        b = (b * b) % mod;
        e = e / 2;
    }
    return result;
}

let sum = 0;
let i = 0;
while (i < 10000) {
    sum = sum + mod_exp(3, 1000, 1000000007);
    i = i + 1;
}
let end = Date.to_millis();
print("Sum: " + sum);
print("Time: " + (end - start) + "ms");

