fn is_prime(n) {
    if (n < 2) { return false; }
    if (n == 2) { return true; }
    if (n % 2 == 0) { return false; }
    let i = 3;
    while (i * i <= n) {
        if (n % i == 0) { return false; }
        i = i + 2;
    }
    return true;
}
let count = 0;
let n = 2;
let start = Date.to_millis();
while (n <= 100000) {
    if (is_prime(n)) { count = count + 1; }
    n = n + 1;
}
let end = Date.to_millis();
print("Primes: " + count);
print("Time: " + (end - start) + "ms");

