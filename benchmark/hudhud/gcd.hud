fn gcd(a, b) {
    while (b != 0) {
        let temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}
let start = Date.to_millis();
let result = 0;
for (let i = 1; i <= 10000; i = i + 1) {
    result = gcd(i * 12345, i * 6789 + 1);
}
let end = Date.to_millis();
print("Result: " + result);
print("Time: " + (end - start) + "ms");

