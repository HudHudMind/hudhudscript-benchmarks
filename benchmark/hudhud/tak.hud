fn tak(x, y, z) {
    if (y < x) {
        return tak(
            tak(x - 1, y, z),
            tak(y - 1, z, x),
            tak(z - 1, x, y)
        );
    }
    return z;
}

let start = Date.to_millis();
let res = 0;
let i = 0;
while (i < 10) {
    res = tak(18, 12, 6);
    i = i + 1;
}
let end = Date.to_millis();

print("Result: " + res);
print("Time: " + (end - start) + "ms");
