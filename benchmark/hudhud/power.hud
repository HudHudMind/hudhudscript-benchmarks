fn power(base, exp) {
    let result = 1;
    for (let i = 0; i < exp; i = i + 1) {
        result = result * base;
    }
    return result;
}
let sum = 0;
let start = Date.to_millis();
for (let i = 0; i < 10000; i = i + 1) {
    sum = sum + power(2, 1000);
}
let end = Date.to_millis();
print("Sum: " + sum);
print("Time: " + (end - start) + "ms");
