let n = 100000;
let arr = [];
for (let i = 1; i <= n; i = i + 1) {
    arr.push(i);
}
let start = Date.to_millis();
let cum = [];
let s = 0;
for (let i = 0; i < n; i = i + 1) {
    s = s + arr[i];
    cum.push(s);
}
let end = Date.to_millis();
print("Last: " + cum[n - 1]);
print("Time: " + (end - start) + "ms");

