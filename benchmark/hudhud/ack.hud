fn ack(m, n) {
    if (m == 0) {
        return n + 1;
    }
    if (n == 0) {
        return ack(m - 1, 1);
    }
    return ack(m - 1, ack(m, n - 1));
}
let start = Date.to_millis();
let result = ack(3, 6);
let end = Date.to_millis();
print("Result: " + result);
print("Time: " + (end - start) + "ms");

