fn fib(n) {
    if (n <= 1) {
        return n;
    }
    let a = 0;
    let b = 1;
    for (let i = 2; i <= n; i = i + 1) {
        let temp = a + b;
        a = b;
        b = temp;
    }
    return b;
}
let start = Date.to_millis();
let sum = 0;
for (let i = 0; i < 10000; i = i + 1) {
    sum = sum + fib(1000);
}
let end = Date.to_millis();
print("Sum: " + sum);
print("Time: " + (end - start) + "ms");

